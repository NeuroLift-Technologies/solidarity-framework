      }
    ],
    "next_agent_notes": "REPLACE_WITH_FREEFORM_NOTES — what the next agent absolutely must know before picking up this work",
    "files_modified": [
      "REPLACE_WITH_FILE_PATH_1",
      "REPLACE_WITH_FILE_PATH_2"
    ],
